# Copy this file to `.env` and fill in the values.
#
# These come from `npx supabase start` (the local dev stack).
# The anon key is safe to expose in the client — Row-Level Security protects data.
#
# EXPO_PUBLIC_SUPABASE_URL host depends on where the app runs:
#   - iOS simulator:      http://127.0.0.1:54321
#   - Android emulator:   http://10.0.2.2:54321
#   - Physical device:    http://<your-computer-LAN-IP>:54321  (e.g. http://192.168.1.50:54321)

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Optional: Mapbox public access token (pk...) for venue search and maps.
# Create one at https://account.mapbox.com/access-tokens/. Without it, venue
# search falls back to manual name/city entry.
EXPO_PUBLIC_MAPBOX_TOKEN=

# Mapbox secret download token (sk...) with the DOWNLOADS:READ scope. Build-time
# only — no EXPO_PUBLIC_ prefix so it's never bundled into the app. Required to
# build the native map. For EAS builds, set it as an EAS environment variable.
MAPBOX_DOWNLOAD_TOKEN=
