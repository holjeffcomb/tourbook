# Secrets for local Edge Function development (`supabase functions serve`).
# Copy to `supabase/functions/.env` (gitignored) and fill in. For deployed
# functions, set these with: supabase secrets set OPENAI_API_KEY=...
OPENAI_API_KEY=
# Optional: override the model used by parse-tour.
OPENAI_MODEL=gpt-4o-mini
